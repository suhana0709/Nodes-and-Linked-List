#counting the frequency of each character in a string
def frequency(s):
    # creating a dictionary to store the frequency
    s = s.lower()  #ignoring cases
    d = {}
    #loop 
    for i in range(len(s)):
        #checking if the character is already in the dictionary
        if s[i] in d.keys():
            d[s[i]] += 1
        else:
            d[s[i]] = 1
    return d
    
#driver code
print("Finding the Frequency:- ")
inp = input("Enter the String: ")
print(frequency(inp))
