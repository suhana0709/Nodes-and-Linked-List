def nextword(s):
    if (s == ""):
        return "a"
    
    i = len(s) - 1
    while (i >=0 and s[i] == 'z'):
        i -= 1
    
    if (i == -1):
        s = s + 'a'
    else:
        s = s[:i] + chr(ord(s[i])+1) + s[i+1:]
    
    return s
    
inp = input("Enter string: ")
print(nextword(inp))
