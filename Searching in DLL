class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
        self.prev = None
        
class DLL:
    def __init__(self):
        self.head = None
    
    def Search(self, data):
        t = 0
        temp = self.head
        while temp: 
            #traversing the list through temp
            if temp.data == data:
                t = 1
                break   #break the loop when element s found
            temp = temp.next
        
        if t == 1:
            print("Element Found.")
        else:
            print("Element not Found.")
            
    def Display(self):
        if self.head == None:
            print("List is Empty.")
        else:
            temp = self.head
            while temp:
                print(temp.data, "--->",end=" ")
                temp = temp.next
                
                
